#!/usr/bin/env bash
# Regenerate BuildInfo.swift with current git metadata, then `swift build`.
#
# `git checkout` invalidates .build/debug/ artifacts but does NOT trigger
# a rebuild, so callers like `bin/run-shortcut-test` (which falls back to
# the cached debug binary) can silently use stale compiler output. Using
# this script as the build entry point keeps the embedded git SHA in sync
# with the source tree, and the SHA is stamped onto every compiled
# .shortcut so stale-binary footguns are visible from inside the app.
#
# Usage:
#   bin/build              # debug build
#   bin/build --release    # passes flags through to swift build

set -euo pipefail

cd "$(dirname "$0")/.."

if git rev-parse --git-dir >/dev/null 2>&1; then
    SHA="$(git rev-parse --short HEAD)"
    DESCRIBE="$(git describe --tags --always --dirty 2>/dev/null || git rev-parse --short HEAD)"
else
    SHA="unknown"
    DESCRIBE="unknown"
fi
DATE="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

cat > Sources/perspective-cuts/CLI/BuildInfo.swift <<EOF
// Generated by bin/build — do not edit. Committed defaults are "unknown".
enum BuildInfo {
    static let gitSha: String = "${SHA}"
    static let gitDescribe: String = "${DESCRIBE}"
    static let buildDate: String = "${DATE}"

    static var versionString: String {
        "0.1.0 (\(gitDescribe))"
    }

    static var compiledByLine: String {
        "Compiled with perspective-cuts \(gitDescribe) on \(buildDate)"
    }
}
EOF

exec swift build "$@"
